{
  "name": "digitalocean-ai-provider",
  "version": "0.1.0",
  "description": "DigitalOcean AI Provider for the Vercel AI SDK - Integrate with DigitalOcean's Gradient AI Platform agents",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:clean": "rm -rf dist && npm run build",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit",
    "validate": "npm run lint && npm run test",
    "prepare": "npm run build",
    "prepublishOnly": "npm run validate && npm run build:clean",
    "release": "./scripts/release.sh",
    "release:patch": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "keywords": [
    "ai",
    "ai-sdk",
    "digitalocean",
    "gradient-ai",
    "language-model",
    "llm",
    "vercel",
    "openai-compatible",
    "chatbot",
    "text-generation",
    "streaming",
    "typescript"
  ],
  "author": "Rosiel Victor <rosielvictor.dev@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/misterioso013/digitalocean-ai-provider#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/misterioso013/digitalocean-ai-provider.git"
  },
  "bugs": {
    "url": "https://github.com/misterioso013/digitalocean-ai-provider/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/misterioso013"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^4.0.19",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "ai": "^6.0.116",
    "dotenv": "^16.6.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
